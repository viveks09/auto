# ─── Jira On-Premise Configuration ──────────────────────────────────────────
# Base URL of your internal Jira instance — no trailing slash
# Examples:
#   http://jira.yourcompany.com
#   https://jira.yourcompany.com
#   http://jira.yourcompany.com:8080
JIRA_BASE_URL=http://jira.yourcompany.com

# Your Jira username (for on-premise this is usually your username, not email)
JIRA_EMAIL=your-jira-username

# Jira API token or password
# On-premise / Data Center: use an API token from your Jira profile
#   Profile → Manage Account → Security → API Tokens
# Older Jira Server (<8.14): use your Jira password if API tokens are not available
JIRA_API_TOKEN=your_jira_api_token_or_password

# ─── GitHub Configuration ────────────────────────────────────────────────────
# GitHub auth is handled by gh CLI — run `gh auth login` once.
# No token needed here.
GITHUB_ORG=your-github-org-or-username
DEFAULT_BASE_BRANCH=main

# ─── Optional: Custom Jira Field IDs ─────────────────────────────────────────
# If your Jira has a custom field for GitHub repo name, add its ID here.
# Find field IDs at: http://jira.yourcompany.com/rest/api/2/field
# JIRA_REPO_FIELD_IDS=customfield_10500,customfield_10600

# If your Jira uses a non-standard field for story points:
# JIRA_STORY_POINTS_FIELD=customfield_10028

# If your Jira has a dedicated Acceptance Criteria custom field:
# JIRA_AC_FIELD=customfield_10501

# If your Jira uses a non-standard field for sprint info:
# JIRA_SPRINT_FIELD=customfield_10020

# ─── Angular Frontend Bootstrapping ─────────────────────────────────────────
# Full path to the company Angular starter repo: <org>/<repo>
# This repo is used as the base for all new Angular frontend projects.
# Copilot clones it, strips the git history, and pushes clean to a new repo.
ANGULAR_STARTER_REPO=company-org/angular-starter

# Optional: fix the frontend repo name instead of prompting
# Useful when a ticket always maps to the same frontend repo
# FRONTEND_REPO_NAME=my-app-frontend

# ─── Database (required when Copilot sets up a new application) ─────────────
# Used in generated application.yml as default placeholder values.
# These are for LOCAL DEVELOPMENT only — never commit real credentials.
# DB_USERNAME=myapp_user
# DB_PASSWORD=changeme

# ─── Optional: PR Reviewers ───────────────────────────────────────────────────
# REVIEWERS=reviewer1,reviewer2

# ─── Optional: Playwright E2E ────────────────────────────────────────────────
BASE_URL=http://localhost:4200
